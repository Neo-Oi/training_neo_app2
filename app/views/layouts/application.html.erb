<!DOCTYPE html>
<html>
  <head>
    <title><%= yield(:title).presence || "プライムテック研修開発" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header>
    <div>
    <h1 class="title"><%= content_for(:title) || "未設定ページ" %></h1>
    </div>

    <ul class="menu-groupe">
    <li class="menu-item">
      <% if current_user&.name.present? %>
        <%= button_to "マイページへ",user_path(current_user),method: :get %>
      <% else %>
        こんにちはゲストさん
      <% end %>
      </li>

      <% if current_user&.present? %>
        <li class="menu-item"><%= button_to "ホームページへ", homes_path,method: :get %></li>
      <% end %>

      <li class="menu-item">
      <% if current_user&.role == "member" %>
        権限:一般
      <% elsif current_user&.role == "admin" %>
        <%= button_to "権限:管理者", users_path,method: :get %>
      <% else %>
        権限:未ログイン
      <% end %>
      </li>


      <li class="menu-item">
      通知:
      <% if flash[:notice] == nil %>
        ありません
      <% else %>
        <%= flash[:notice] %>
      <% end %>
      </li>
    </ul>
<br>
    <ul class="menu-groupe">
    <% if current_user&.present? %>
        <li class="menu-item"><%=button_to "ログアウト",logout_path,method: :delete%>
      <% end %>
      </li>
      <li class="menu-item">
      <% if current_user&.name.present? %>
        <%= "ログイン：#{current_user.name}"%>
      <% end %>
      </li>
    </ul>


  </header>
    <%= yield %>
  <footer>
  </footer>
    
  </body>
</html>
