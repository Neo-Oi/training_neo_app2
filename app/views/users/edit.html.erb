<% content_for :title, "編集ページ" %>


    <div class = "user_box">
<%= form_with model: @user do |f| %>
  <div>
    <%= f.label :name %>
    <%= f.text_field :name, class: "form-field", placeholder: "#{@user.name}" %>
  </div>
    
  <div>
    <%= f.label :email %>
    <%= f.email_field :email, class: "form-field", placeholder: "#{@user.email}" %>
  </div>

  <div>
    <%= f.label :password %>
    <%= f.password_field :password, class: "form-field", placeholder: "password" %>
  </div>

  <div>
    <%= f.label :role %>
    <%= f.select :role, [["一般ユーザー", "member"], ["管理者", "admin"]],{},{class: 'form-field'}%>
  <%= f.submit "登録",class: "form-button"  %>
<% end %>
  </div>
</div>

    <div>
        <%= button_to "対象ユーザの削除", user_path(@user),method: :delete,class: "button",data: { turbo_confirm: "本当に#{@user.name}を削除しますか？" } %>
    </div>